#!/usr/bin/env bash
# fzf-fftools: FFmpeg 工具箱主循环
set -u

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
source "$script_dir/fzf-fftools-lib"

OPS=(
    "1. 命令构建器    fzf-ffmpeg-builder     编码器+滤镜+硬件加速"
    "2. 快速预设      fzf-ffmpeg-preset      一键硬件/软件方案"
    "3. 裁剪片段      fzf-trim-video         按时间裁剪"
    "4. 提取音频      fzf-extract-audio      从视频提取音频"
    "5. 移除音频      fzf-mute-video         删除音轨"
    "6. 合并音视频    fzf-merge-av           mkv 封装"
    "7. 拼接视频      fzf-concat-video       合并多片段"
    "8. 烧录字幕      fzf-burn-subs          嵌入字幕"
    "9. 视频转GIF     fzf-video-to-gif       生成动图"
    "A. 变速处理      fzf-speed-video        加速/减速"
    "B. 批量转码      fzf-ffmpeg-batch       批量处理"
    "C. 色彩管理      fzf-ffmpeg-color       HDR/SDR/色域"
    "D. 媒体转换      fzf-convert-media      视频/音频/图片格式"
    "V. 媒体验证      fzf-validate-media     检查文件完整性"
    "W. 添加水印      fzf-add-watermark      文字/图片水印"
    "P. 媒体浏览      __browse_media         图片/视频帧/音频封面"
)

while true; do
    SEL=$(printf '%s\n' "${OPS[@]}" | fzf "${FZF_BASE[@]}" --height 70% --header 'FFmpeg 工具箱 (q 或 Esc 退出)' \
        --bind 'q:abort' --bind 'esc:abort' \
        --preview 'printf "%s - %s\n" "{2}" "{4}"' --preview-window 'bottom:1:wrap')
    [[ -z "$SEL" ]] && break

    CMD=$(echo "$SEL" | awk '{print $3}')
    if [[ "$CMD" == "__browse_media" ]]; then
        media=$(pick_media) || continue
        clear
        FZF_PREVIEW_COLUMNS="${COLUMNS:-80}" FZF_PREVIEW_LINES="${LINES:-30}" "$PVID" "$media"
        echo
        read -r -p "按 Enter 返回菜单..."
    elif command -v "$CMD" &>/dev/null; then
        "$CMD"
        echo
        read -r -p "按 Enter 返回菜单..."
    else
        echo "未找到: $CMD"
        sleep 1
    fi
done
