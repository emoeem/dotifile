#!/usr/bin/fish
# fzf 搜索目录并 cd
set dir (fd --type d --hidden --follow --max-depth 8 --exclude .git --exclude node_modules --exclude .cache --exclude target 2>/dev/null | fzf --prompt "Cd> " --preview 'eza -T --level=2 --color=always {} | head -200' --preview-window right:60%:wrap)
if test -n "$dir"
    cd "$dir"
end
